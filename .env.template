APP_NAME='Knowledge Assistant'
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

DATABASE_USER=<db-user>
DATABASE_PASSWORD=<db-password>
DATABASE_NAME=<db-name>

DATABASE_URL=postgresql+psycopg2://$DATABASE_USER:$DATABASE_PASSWORD@db:5432/$DATABASE_NAME

DEFAULT_TOP_K=5
DEFAULT_MAX_CONTEXT_CHUNKS=4
DEFAULT_CHUNK_SIZE=700
DEFAULT_CHUNK_OVERLAP=120

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768
EMBEDDING_CACHE_DIR=/root/.cache/huggingface/sentence-transformers

LLM_PROVIDER=local
LLM_MODEL=qwen3:14b
LLM_API_KEY=your_api_key_here
LLM_API_URL=http://host.docker.internal:11434/api/chat

ENABLE_CACHE=true
CACHE_TTL_SECONDS=300

ENABLE_RERANKER=true
RERANKER_PROVIDER=heuristic
RERANKER_CANDIDATE_POOL=8
